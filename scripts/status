#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
workspace_root="${SHARED_WORKSPACE_ROOT:-$repo_root}"

repos=(
  nixpkg-canopy
  nixpkg-claude-code
  nixpkg-claude-agent-acp
  nixpkg-code-intel-rust
  nixpkg-code-intel-ts
  nixpkg-codex
  nixpkg-codex-acp
  nixpkg-context-mode-cli
  nixpkg-context-mode-mcp
  nixpkg-gemini
  nixpkg-mulch
  nixpkg-nixos-cli
  nixpkg-overstory
  nixpkg-pi-coding-agent
  nixpkg-repo-map
  nixpkg-seeds
  nixpkg-trellis
)

for repo in "${repos[@]}"; do
  target="$workspace_root/$repo"
  echo "== $repo =="
  if [ ! -d "$target/.git" ]; then
    echo "missing"
    continue
  fi

  git -C "$target" status --short --branch
done
